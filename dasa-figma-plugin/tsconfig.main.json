{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["@figma/plugin-typings"],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/main/**/*", "src/shared/**/*", "src/kb/**/*"],
  "exclude": ["node_modules", "dist", "src/ui/**/*"]
}
