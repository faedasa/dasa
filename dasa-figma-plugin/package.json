{
  "name": "dasa-figma-plugin",
  "version": "1.0.0",
  "description": "Dasa Design Quality Checklist - Figma Plugin",
  "scripts": {
    "sync-kb": "node scripts/sync-kb.mjs",
    "build": "npm run sync-kb && node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.ui.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.90.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  },
  "private": true
}
